<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tiger.job.common.mapper.UserMapper">

    <resultMap type="com.tiger.job.common.entity.SysUser" id="SysUserResult">
        <id     property="id"       column="id"        />
        <result property="userName" column="user_name" />
        <result property="password" column="password"  />
        <result property="delFlag"  column="del_flag"  />
    </resultMap>

    <select id="selectUserByUserName" parameterType="string" resultMap="SysUserResult">
        select id,user_name,password,del_flag
        from sys_user
        where user_name = #{userName}
        and del_flag = 0
    </select>

    <select id="selectUserById" parameterType="string" resultMap="SysUserResult">
        select id,user_name,password,del_flag
        from sys_user
        where id = #{id}
        and del_flag = 0
    </select>

    <insert id="registerUser" parameterType="com.tiger.job.common.entity.SysUser">
        insert
        into sys_user(`id`,`user_name`,`password`,`del_flag`)
        values (#{id},#{userName},#{password},#{delFlag})
    </insert>

    <update id="updateUser" parameterType="com.tiger.job.common.entity.SysUser">
        update sys_user
        set `user_name` = #{userName}
        where `id` = #{id} and del_flag = 0
    </update>

    <update id="updatePassword" parameterType="map">
        update sys_user
        set `password` = #{newPassword}
        where `id` = #{id} and `password` = #{oldPassword} and del_flag = 0
    </update>

    <delete id="deleteUserById" parameterType="string">
        delete
        from sys_user
        where `id` = #{id} and del_flag = 0
    </delete>

</mapper>